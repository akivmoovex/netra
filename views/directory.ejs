<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Directory | Netra Zambia</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <%- include('partials/site_header') %>

    <div class="container">
      <div style="margin:18px 0;">
        <div class="section-title" style="margin-top:0;">
          <% if (selectedCategory) { %>
            Category: <%= selectedCategory %>
          <% } else { %>
            Browse Categories
          <% } %>
        </div>
      </div>

      <div class="hero-grid" style="grid-template-columns: 0.9fr 1.1fr;">
        <div class="card">
          <div style="font-weight:900;margin-bottom:12px;">Categories</div>
          <div class="list">
            <a href="/directory" class="btn" style="justify-content:flex-start;width:100%;">All</a>
            <% categories.forEach(function(cat) { %>
              <a
                href="/directory?category=<%= cat.slug %>"
                class="btn"
                style="justify-content:flex-start;width:100%;background:<%= selectedCategory === cat.slug ? 'rgba(79,140,255,0.16)' : 'rgba(255,255,255,0.06)' %>;"
              >
                <%= cat.name %>
              </a>
            <% }) %>
          </div>
        </div>

        <div>
          <div class="list">
            <% if (companies.length === 0) { %>
              <div class="card">No companies found.</div>
            <% } else { %>
              <% companies.forEach(function(c) { %>
                <a class="card" href="<%= buildCompanyUrl({ baseDomain: baseDomain, subdomain: c.subdomain }) %>" target="_blank" rel="noreferrer" style="display:block;">
                  <div class="row-between" style="gap:8px;">
                    <div style="font-weight:900;font-size:16px;"><%= c.name %></div>
                    <div class="muted" style="font-size:12px;">@<%= c.subdomain %></div>
                  </div>
                  <% if (c.headline) { %>
                    <div class="muted" style="margin-top:6px;line-height:1.5;"><%= c.headline %></div>
                  <% } %>
                </a>
              <% }) %>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <%- include('partials/site_footer') %>
    <script src="/scripts.js"></script>
  </body>
</html>

