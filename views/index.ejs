<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Netraz - A to Z for digital lead generation</title>
    <meta
      name="description"
      content="From invisible to in-demand: we build digital systems that bring clients to you."
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body class="home-page">
    <%- include('partials/site_header') %>

    <div class="hero container">
      <div>
        <h1 class="title">From invisible to in-demand: we build digital systems that bring clients to you.</h1>
        <p class="subtitle">
          We help companies attract, engage, and convert customers through websites, social media, and digital campaigns.
        </p>

        <div class="pill-row" aria-label="Services">
          <div class="pill">🌐 Website Development</div>
          <div class="pill">📱 Social Media Growth</div>
          <div class="pill">📈 Digital Campaigns</div>
        </div>

        <div class="hero-actions">
          <a class="btn btn-primary" href="/directory">Browse Directory</a>
          <a class="btn" href="/admin/login">Get Started</a>
        </div>
      </div>
    </div>

    <div class="container">
      <div class="section-block section-block--lg">
        <div class="section-title">Your digital presence should generate business</div>
        <p class="subtitle" style="margin-bottom:0;">
          Your website shouldn’t just exist. Your social media shouldn’t just post. Everything you do online should bring
          you real customers.
        </p>
      </div>

      <div class="section-block">
        <div class="section-title">What we build</div>
        <div class="grid-3">
          <div class="card">
            <div style="font-weight:900;font-size:16px;margin-bottom:6px;">🌐 Website Development</div>
            <div class="muted">Modern, fast websites designed to convert visitors into leads.</div>
          </div>

          <div class="card">
            <div style="font-weight:900;font-size:16px;margin-bottom:6px;">📱 Social Media Growth</div>
            <div class="muted">Build trust and turn your audience into customers.</div>
          </div>

          <div class="card">
            <div style="font-weight:900;font-size:16px;margin-bottom:6px;">📈 Digital Campaigns</div>
            <div class="muted">Targeted campaigns that bring qualified leads.</div>
          </div>
        </div>
      </div>

      <div class="section-block">
        <div class="section-title">How It Works</div>
        <p class="subtitle" style="margin-bottom:0;">Audit → Build → Launch → Optimize</p>
      </div>

      <div class="section-block">
        <div class="section-title">Why Netraz</div>
        <div class="list" style="margin-top:10px;">
          <div class="muted">Focus on real results</div>
          <div class="muted">Systems, not one-off projects</div>
          <div class="muted">Technical + marketing expertise</div>
        </div>
      </div>

      <div class="card cta-card section-block">
        <div class="section-title" style="margin:0 0 10px;">Your next customer is already online</div>
        <p class="subtitle" style="margin:0 0 14px;">Let’s build a system that brings them to you.</p>
        <a class="btn btn-primary" href="/admin/login">Get Started</a>
      </div>

      <div class="section-block">
        <div class="section-title">Directory Categories</div>
        <div class="grid-3">
          <% categories.forEach(function(cat) { %>
            <a class="card" href="/category/<%= cat.slug %>" style="display:block;">
              <div style="font-weight:900;font-size:16px;margin-bottom:6px;"><%= cat.name %></div>
              <div class="muted" style="font-size:13px;line-height:1.5;">
                One-page company sites inside this category.
              </div>
            </a>
          <% }) %>
        </div>
      </div>
    </div>

    <%- include('partials/site_footer') %>

    <script src="/scripts.js"></script>
  </body>
</html>

